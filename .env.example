# Environment Variables
# Copy this file to .env and configure for your needs

# API Configuration
API_TITLE=SentimentPulse API
API_VERSION=2.0.0
PORT=8000
HOST=0.0.0.0

# Model Configuration
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
BATCH_SIZE=32
MAX_LENGTH=512

# Caching
CACHE_SIZE=1000
CACHE_TTL=3600

# Rate Limiting
RATE_LIMIT_ENABLED=true
REDIS_URL=redis://localhost:6379

# Logging
LOG_DIR=logs
LOG_LEVEL=INFO

# Monitoring
SENTRY_DSN=

# CORS
CORS_ORIGINS=*

# Environment
ENVIRONMENT=development
